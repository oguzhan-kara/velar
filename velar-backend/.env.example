SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_JWT_SECRET=your-jwt-secret-here
DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project-id.supabase.co:5432/postgres
ENVIRONMENT=development
DEBUG=true

# Optional: for live auth and RLS tests
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=testpassword
TEST_USER2_EMAIL=test2@example.com
TEST_USER2_PASSWORD=testpassword2

# Voice pipeline (Phase 2)
ANTHROPIC_API_KEY=sk-ant-...
ELEVENLABS_API_KEY=...
WHISPER_MODEL_SIZE=large-v3-turbo

# Memory system (Phase 3)
OPENAI_API_KEY=sk-...

# Integrations (Phase 4)
# Google Calendar — download credentials JSON from Google Cloud Console
# (APIs & Services > Credentials > OAuth 2.0 Client ID > Desktop app)
GOOGLE_CALENDAR_CREDENTIALS_PATH=~/.velar/google_credentials.json

# OpenWeatherMap — subscribe to "One Call by Call" at openweathermap.org/api
OPENWEATHERMAP_API_KEY=...
WEATHER_CITY=Istanbul

# Google Places (New) — enable "Places API (New)" in Google Cloud Console
GOOGLE_PLACES_API_KEY=...
PLACES_CITY=Istanbul

# ---------------------------------------------------------------------------
# Free tier providers (default — no paid API keys needed for edge+local)
# ---------------------------------------------------------------------------
LLM_PROVIDER=groq            # "groq" | "gemini" | "anthropic"
EMBEDDING_PROVIDER=local     # "local" | "openai"
TTS_PROVIDER=edge            # "edge"  | "elevenlabs"

# Free LLM options (pick one — set LLM_PROVIDER accordingly):
GROQ_API_KEY=gsk_...         # Groq (Llama 3.3 70B) — get free at console.groq.com  ← RECOMMENDED
GOOGLE_AI_API_KEY=...        # Gemini Flash — get free at aistudio.google.com

# Switch to paid provider for higher quality:
# LLM_PROVIDER=anthropic   → uses ANTHROPIC_API_KEY (Claude Haiku)
# EMBEDDING_PROVIDER=openai → uses OPENAI_API_KEY (text-embedding-3-small, 1536 dims)
# TTS_PROVIDER=elevenlabs  → uses ELEVENLABS_API_KEY (eleven_flash_v2_5, 75ms latency)
#
# Note: switching EMBEDDING_PROVIDER=openai also requires running migration:
#   supabase/migrations/20260302000002_embeddings_384dim.sql (in reverse — alter to 1536)
